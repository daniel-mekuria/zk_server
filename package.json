{
  "name": "zk-push-server",
  "version": "1.0.0",
  "description": "ZKTeco PUSH Protocol Server for syncing user and biometric data",
  "main": "server.js",
  "scripts": {
    "start": "node server.js > output.txt",
    "dev": "nodemon server.js",
    "test": "jest --verbose"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/*.test.js"],
    "collectCoverageFrom": ["*.js", "!server.js"]
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "dotenv": "^17.0.1",
    "express": "^4.18.2",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "fast-check": "^4.7.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "zkteco",
    "push",
    "protocol",
    "biometric",
    "attendance"
  ],
  "author": "",
  "license": "MIT"
}
